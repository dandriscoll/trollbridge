[Unit]
Description=drawbridge LLM-aware HTTP/HTTPS proxy
Documentation=https://github.com/dandriscoll/drawbridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=drawbridge
Group=drawbridge
ExecStart=/usr/local/bin/drawbridge run --config /etc/drawbridge/drawbridge.yaml
ExecReload=/bin/kill -HUP $MAINPID
KillSignal=SIGTERM
TimeoutStopSec=45
Restart=on-failure
RestartSec=5

# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
PrivateTmp=true
PrivateDevices=true
ProtectKernelTunables=true
ProtectKernelModules=true
ProtectControlGroups=true
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=true
RestrictRealtime=true
LockPersonality=true
MemoryDenyWriteExecute=true
ReadWritePaths=/var/log/drawbridge /etc/drawbridge

# CAP_NET_BIND_SERVICE only needed when binding ports < 1024.
# AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
